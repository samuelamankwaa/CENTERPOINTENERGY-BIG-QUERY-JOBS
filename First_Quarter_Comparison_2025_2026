WITH base_events AS (
  SELECT
    ef.EVENTKEY,
    ef.EVENTNAME,
    ef.STARTDATETIME,
    ef.RESTOREDDATETIME,
    ef.SERVICECENTER,
    ef.DURATIONHM,
    ef.DEVICENAME
  FROM `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_EVENT_FACT` ef
  WHERE ef.STARTDATETIME >= DATETIME('2025-01-01 00:00:00')
    AND ef.STARTDATETIME <  DATETIME('2025-04-01 00:00:00')     -- end exclusive
    AND ef.EXCLUDETROUBLEFLAG = 0
    AND ef.MOMENTARYOUTAGEFLAG = 0
    AND ef.CANCELLEDFLAG = 0
    AND ef.PLANNEDOTGFLAG = 0
    AND ef.NONOUTGCALLFLAG = 0
    AND ef.ORPHANOUTAGEFLAG = 0
    AND ef.SERVICECENTER NOT IN ('BV', 'EV', 'FB', 'MV', 'RP', 'INDIANA')
),

events_with_history AS (
  SELECT
    e.* EXCEPT(DEVICENAME),
    h.ACTUALPERIODSTART
  FROM base_events e
  INNER JOIN `cnp-datafoundation-prod.ADMS_OEP.T_FPRP_OUTAGE_HIST` h
    ON h.EVENTNAME = e.EVENTNAME
  WHERE h.ACTUALPERIODSTART >= DATETIME('2025-01-01 00:00:00')
    AND h.ACTUALPERIODSTART <  DATETIME('2025-04-01 00:00:00')
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY e.EVENTNAME
    ORDER BY h.ACTUALPERIODSTART DESC
  ) = 1          -- one row per EVENTNAME here
),

call_ranked AS (
  SELECT
    cf.EVENTKEY,
    cf.CALLDESC,
    cf.NO_CALLS,
    ROW_NUMBER() OVER (
      PARTITION BY cf.EVENTKEY
      ORDER BY cf.NO_CALLS DESC
    ) AS rn_call
  FROM `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_CALL_FACT` cf
  INNER JOIN events_with_history e
    ON cf.EVENTKEY = e.EVENTKEY
),

service_suite_raw AS (
  SELECT
    ss.EVENTNAME,
    ss.OUTAGE_CAUSE_CODE,
    ss.OUTAGE_CAUSE_DESC,
    ss.TRUCK_NUMBER,
    ss.CREW_NAME,
    ss.CREW_NOTES AS COMMENTS,
    TRIM(
      CONCAT(
        COALESCE(ss.ACTION_TAKEN_1, ''), 
        CASE WHEN ss.ACTION_TAKEN_2 IS NOT NULL THEN ' . ' || ss.ACTION_TAKEN_2 END,
        CASE WHEN ss.ACTION_TAKEN_3 IS NOT NULL THEN ' . ' || ss.ACTION_TAKEN_3 END,
        CASE WHEN ss.ACTION_TAKEN_4 IS NOT NULL THEN ' . ' || ss.ACTION_TAKEN_4 END,
        CASE WHEN ss.ACTION_TAKEN_5 IS NOT NULL THEN ' . ' || ss.ACTION_TAKEN_5 END,
        CASE WHEN ss.ACTION_TAKEN_6 IS NOT NULL THEN ' . ' || ss.ACTION_TAKEN_6 END
      )
    ) AS action_taken_ss,
    ARRAY_LENGTH(
      ARRAY(
        SELECT x
        FROM UNNEST([
          ss.ACTION_TAKEN_1, ss.ACTION_TAKEN_2, ss.ACTION_TAKEN_3,
          ss.ACTION_TAKEN_4, ss.ACTION_TAKEN_5, ss.ACTION_TAKEN_6
        ]) x
        WHERE x IS NOT NULL
      )
    ) AS action_count_ss
  FROM `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_SERVICE_SUITE` ss
  INNER JOIN events_with_history e
    ON ss.EVENTNAME = e.EVENTNAME
),

-- If service suite can have multiple rows per EVENTNAME, pick one
service_suite AS (
  SELECT *
  FROM (
    SELECT
      ss.*,
      ROW_NUMBER() OVER (
        PARTITION BY ss.EVENTNAME
        ORDER BY ss.action_count_ss DESC, ss.EVENTNAME
      ) AS rn_ss
    FROM service_suite_raw ss
  )
  WHERE rn_ss = 1
),

actions_agg AS (
  SELECT
    eventname,
    STRING_AGG(action_taken_name, ' , ' ORDER BY action_taken_name) AS action_taken_all
  FROM `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_ALL_ACTIONS_TAKEN`
  WHERE eventname IN (SELECT EVENTNAME FROM events_with_history)
  GROUP BY eventname
),

tasks_raw AS (
  SELECT
    DISTINCT
    A.Tasks.WorkOrderTask.TaskTracking.EventByUserId AS EventByUserId,
    A.OrderNumber AS EVENTNAME
  FROM `cnp-datafoundation-prod.EAI_ELEC_OPS.T_ELEC_ORDER_TASKS` A
  WHERE A.OrderUpdateTS >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 600 DAY)
    AND A.OrderUpdateTS <= CURRENT_TIMESTAMP()
    AND A.OrderNumber IN (SELECT EVENTNAME FROM events_with_history)
),

-- If there can be multiple task rows per EVENTNAME, pick one
tasks AS (
  SELECT *
  FROM (
    SELECT
      t.*,
      ROW_NUMBER() OVER (
        PARTITION BY t.EVENTNAME
        ORDER BY t.EventByUserId
      ) AS rn_task
    FROM tasks_raw t
  )
  WHERE rn_task = 1
),

final_with_possible_dupes AS (
  SELECT
    e.EVENTNAME,
    e.STARTDATETIME,
    e.RESTOREDDATETIME,
    e.SERVICECENTER,
    ss.OUTAGE_CAUSE_DESC,
    FALSE AS MOMENTARYOUTAGEFLAG,             -- fixed by base filter
    FALSE AS PLANNEDOTGFLAG,                  -- fixed by base filter
    COALESCE(a.action_taken_all, '') AS action_taken_from_all_actions,
    e.DURATIONHM,
    ss.CREW_NAME AS COMPLETED_BY,
    t.EventByUserId AS DispatchedBy,
    ss.TRUCK_NUMBER,
    ss.COMMENTS
  FROM events_with_history e
  LEFT JOIN call_ranked c
    ON c.EVENTKEY = e.EVENTKEY
    AND c.rn_call = 1
  LEFT JOIN service_suite ss
    ON ss.EVENTNAME = e.EVENTNAME
  LEFT JOIN actions_agg a
    ON a.eventname = e.EVENTNAME
  LEFT JOIN tasks t
    ON t.EVENTNAME = e.EVENTNAME
),

-- Final de‑duplication: guarantee one row per EVENTNAME
final_dedup AS (
  SELECT
    f.*,
    ROW_NUMBER() OVER (
      PARTITION BY f.EVENTNAME
      ORDER BY f.STARTDATETIME
    ) AS rn_final
  FROM final_with_possible_dupes f
)

SELECT
  EVENTNAME,
  STARTDATETIME,
  RESTOREDDATETIME,
  SERVICECENTER,
  OUTAGE_CAUSE_DESC,
  MOMENTARYOUTAGEFLAG,
  PLANNEDOTGFLAG,
  action_taken_from_all_actions,
  DURATIONHM,
  COMPLETED_BY AS CREW_COMPLETED,
  DispatchedBy AS CONTROLLER_COMPLETED,
  TRUCK_NUMBER,
  COMMENTS
FROM final_dedup
WHERE rn_final = 1
ORDER BY STARTDATETIME;
