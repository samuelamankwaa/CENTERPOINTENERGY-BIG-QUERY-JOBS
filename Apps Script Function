function runBigQueryReportAndEmail() {
  const projectId = 'cnp-datafoundation-prod';
  
  const query = `
WITH raw_orders AS (
  SELECT
    REGEXP_REPLACE(TRIM(CAST(A.Tasks.WorkOrderTask.TaskData.OrderRecord.EsiId AS STRING)), r'[^0-9]', '') AS ESIID_NORM,
    CAST(A.Tasks.WorkOrderTask.TaskData.OrderRecord.EsiId AS STRING) AS ESIID_RAW,
    REGEXP_REPLACE(TRIM(CAST(A.Tasks.WorkOrderTask.TaskData.OrderRecord.MtrNum AS STRING)), r'[^0-9]', '') AS METER_NO,
    A.OrderUpdateTS AS Completion_Date_Raw,           
    A.OrderType AS Job_Code,
    A.OrderNumber,
    A.Tasks.WorkOrderTask.TaskNumber,
    A.Tasks.WorkOrderTask.Organization.DispatchArea AS DispatchArea,
    CASE
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1001' THEN 'SYS - TBL Crew'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1004' THEN 'Meter Lab'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1005' THEN 'South Houston'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1006' THEN 'Spring Branch'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1007' THEN 'Sugar Land'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1008' THEN '3 PH Undergroun'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1012' THEN 'Baytown'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1013' THEN 'Bellaire'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1017' THEN 'Cypress'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1019' THEN 'Katy'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1020' THEN 'HO Clarke'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1021' THEN 'Greenspoint'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1022' THEN 'Galveston'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1023' THEN 'Fort Bend'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1024' THEN 'Humble'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1025' THEN 'Harrisburg'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1028' THEN 'CEHE-TRG-HOC'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1041' THEN 'Heavy Construction NW'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1042' THEN 'Heavy Construction SW'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1043' THEN 'Heavy Construction SE'
    END AS SvC_Cntr,
    A.Tasks.WorkOrderTask.Activities.Activity.ActivityData.ElecOrder.Hco AS Hco,
    A.Tasks.WorkOrderTask.TaskData.OrderRecord.CompStatus AS CompStatus,
    A.Tasks.WorkOrderTask.Location.Address.AddressLineCombine AS Address,
    A.Tasks.WorkOrderTask.TaskAssignment.UserId AS Employee_ID,
    A.Tasks.WorkOrderTask.TaskData.OrderRecord.LastKwh AS Meter_Readings,
    A.Tasks.WorkOrderTask.TaskTracking.CompletedAt.Value AS CompletedAt,
    ROW_NUMBER() OVER (
      PARTITION BY A.OrderNumber
      ORDER BY A.OrderUpdateTS DESC
    ) AS rn
  FROM \`cnp-datafoundation-prod.EAI_ELEC_OPS.T_ELEC_ORDER_TASKS\` A
  WHERE A.OrderUpdateTS >= TIMESTAMP_TRUNC(
          TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 1 DAY),
          DAY
        ) 
    AND A.OrderUpdateTS < TIMESTAMP_TRUNC(
          CURRENT_TIMESTAMP(),
          DAY
    )
    AND A.OrderType IN ('TMDOPS','TMDMTR','TMDCSR','RCTOPS','RCTMTR')
    AND A.Tasks.WorkOrderTask.TaskData.OrderRecord.EsiId IS NOT NULL
    AND A.Tasks.WorkOrderTask.TaskTracking.CompletedAt.Value IS NOT NULL
    AND A.Tasks.WorkOrderTask.Activities.Activity.ActivityData.ElecOrder.TurnDwnCd1 IS NULL
), 
orders AS (
  SELECT
    ESIID_NORM,
    ESIID_RAW,
    METER_NO,
    Completion_Date_Raw,
    Job_Code,
    OrderNumber,
    TaskNumber,
    DispatchArea,
    SvC_Cntr,
    Hco,
    CompStatus,
    Address,
    Employee_ID,
    Meter_Readings,
    CompletedAt
  FROM raw_orders
  WHERE rn = 1
),
tmd_orders AS (
  SELECT *
  FROM orders
  WHERE Job_Code IN ('TMDOPS','TMDMTR','TMDCSR')
),
rct_orders AS (
  SELECT
    ESIID_NORM,
    Completion_Date_Raw AS RCT_Completion_Date,
    OrderNumber AS RCT_OrderNumber,
    Job_Code AS RCT_Job_Code
  FROM orders
  WHERE Job_Code IN ('RCTOPS','RCTMTR')
),
tmd_with_next_rct AS (
  SELECT
    t.ESIID_NORM,
    t.ESIID_RAW,
    t.METER_NO,
    t.Completion_Date_Raw,
    t.Job_Code,
    t.OrderNumber,
    t.TaskNumber,
    t.DispatchArea,
    t.SvC_Cntr,
    t.Hco,
    t.CompStatus,
    t.Address,
    t.Employee_ID,
    t.Meter_Readings,
    t.CompletedAt,
    MIN(r.RCT_Completion_Date) AS Next_RCT_Completion_Date
  FROM tmd_orders t
  LEFT JOIN rct_orders r
    ON r.ESIID_NORM = t.ESIID_NORM
   AND r.RCT_Completion_Date > t.Completion_Date_Raw
  GROUP BY
    t.ESIID_NORM, t.ESIID_RAW, t.METER_NO, t.Completion_Date_Raw, t.Job_Code,
    t.OrderNumber, t.TaskNumber, t.DispatchArea, t.SvC_Cntr, t.Hco,
    t.CompStatus, t.Address, t.Employee_ID, t.Meter_Readings, t.CompletedAt
),
interval_reads AS (
  SELECT
    REGEXP_REPLACE(TRIM(CAST(METER_NO AS STRING)), r'[^0-9]', '') AS METER_NO,
    LOCAL_INTERVAL_END_TIME,
    INTERVAL_VALUE,
    MEAS_TYPE_ID
  FROM \`smart-meter-production.SMF.T_LP_INTERVAL\`
  WHERE
    LOCAL_INTERVAL_END_TIME >= DATETIME(
      DATE_SUB(CURRENT_DATE('America/Chicago'), INTERVAL 1 DAY)
    )
    AND INTERVAL_VALUE > 0
),
final_rows AS (
  SELECT
    t.ESIID_NORM,
    t.ESIID_RAW,
    t.METER_NO,
    t.Completion_Date_Raw,
    t.CompletedAt,
    t.DispatchArea,
    t.SvC_Cntr,
    t.Job_Code,
    t.Hco,
    t.CompStatus,
    t.Address,
    t.Employee_ID,
    t.Meter_Readings,
    t.OrderNumber,
    t.TaskNumber,
    t.Next_RCT_Completion_Date,
    MIN(i.LOCAL_INTERVAL_END_TIME) AS First_Interval_Read_Time,
    MAX(i.INTERVAL_VALUE) AS Max_Interval_Value_After_TMD
  FROM tmd_with_next_rct t
  JOIN interval_reads i
    ON i.METER_NO = t.METER_NO
   AND i.LOCAL_INTERVAL_END_TIME > DATETIME(t.Completion_Date_Raw, 'America/Chicago')
  WHERE t.Next_RCT_Completion_Date IS NULL
  GROUP BY
    t.ESIID_NORM, t.ESIID_RAW, t.METER_NO, t.Completion_Date_Raw, t.CompletedAt,
    t.DispatchArea, t.SvC_Cntr, t.Job_Code, t.Hco, t.CompStatus, t.Address,
    t.Employee_ID, t.Meter_Readings, t.OrderNumber, t.TaskNumber, t.Next_RCT_Completion_Date
)  
SELECT
  CONCAT("'", ESIID_NORM) AS ESIID,
  METER_NO,
  FORMAT_TIMESTAMP('%Y-%m-%d %H:%M:%S', Completion_Date_Raw, 'America/Chicago') AS Completion_Date,
  CompletedAt,
  DispatchArea,
  SvC_Cntr,
  Job_Code,
  Hco,
  CompStatus,
  Address,
  Employee_ID,
  Meter_Readings,
  OrderNumber,
  TaskNumber,
  First_Interval_Read_Time,
  Max_Interval_Value_After_TMD,
  'YES' AS HCO_Error
FROM final_rows
ORDER BY Completion_Date_Raw DESC;
  `;

  const request = {
    query: query,
    useLegacySql: false,
    maximumBytesBilled: 100000000000
  };

  // Run Query
  const queryResults = BigQuery.Jobs.query(request, projectId);
  const jobId = queryResults.jobReference.jobId;

  // Get Results
  let results = BigQuery.Jobs.getQueryResults(projectId, jobId);

  // Populate Sheet
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName('Report') || ss.insertSheet('Report');
  sheet.clear();

  const headers = results.schema.fields.map(f => f.name);
  sheet.appendRow(headers);

  if (results.rows) {
    results.rows.forEach(row => {
      const values = row.f.map(cell => cell.v !== null ? cell.v : '');
      sheet.appendRow(values);
    });
  }

  // Export files
  const dateStr = Utilities.formatDate(new Date(), "GMT", "yyyy-MM-dd");
  
  const urlExcel = ss.getUrl().replace('/edit', '/export?exportFormat=xlsx');
  const urlPdf   = ss.getUrl().replace('/edit', '/export?exportFormat=pdf');

  const blobExcel = UrlFetchApp.fetch(urlExcel, {
    headers: { Authorization: 'Bearer ' + ScriptApp.getOAuthToken() }
  }).getBlob().setName(`Temp_disconnect_with_meter_reads_before_reconnect_worked_last_24hrs_Report_${dateStr}.xlsx`);

  const blobPdf = UrlFetchApp.fetch(urlPdf, {
    headers: { Authorization: 'Bearer ' + ScriptApp.getOAuthToken() }
  }).getBlob().setName(`Temp_disconnect_with_meter_reads_before_reconnect_worked_last_24hrs_Report_${dateStr}.pdf`);

  // Send Email
  const recipients = 'Gregory.Knapp@centerpointenergy.com, Samuel.k.amankwaa@centerpointenergy.com, Binh.Trinh@centerpointenergy.com, justin.linder@CenterpointEnergy.com, charles.guilbeaux@centerpointenergy.com, keaton.odorisio@centerpointenergy.com, jonquil.dillinger@centerpointenergy.com, andrea.reese@centerpointenergy.com';
  
  MailApp.sendEmail(recipients,
    `Meter_Usage_Detected_After_Temporary_Disconnect_Without_Reconnect_Report - ${dateStr}`,
    'Good Morning. \n\n' +
    'Please find the attached for the Temp disconnect with meter reads before reconnect Report. \n\n' +
    'Thank you.',
    { attachments: [blobExcel, blobPdf] }
  );

  console.log('✅ Report generated and emailed successfully!');
}








