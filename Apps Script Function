function runBigQueryReportAndEmail() {
 
  const projectId = 'cnp-datafoundation-prod';
 
  const query = `
WITH base AS (
  SELECT
    A.OrderNumber,
 
    CASE
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1001' THEN 'SYS - TBL Crew'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1004' THEN 'Meter Lab'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1005' THEN 'South Houston'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1006' THEN 'Spring Branch'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1007' THEN 'Sugar Land'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1008' THEN '3 PH Underground'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1012' THEN 'Baytown'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1013' THEN 'Bellaire'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1017' THEN 'Cypress'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1019' THEN 'Katy'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1020' THEN 'HO Clarke'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1021' THEN 'Greenspoint'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1022' THEN 'Galveston'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1023' THEN 'Fort Bend'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1024' THEN 'Humble'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1025' THEN 'Harrisburg'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1028' THEN 'CEHE-TRG-HOC'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1041' THEN 'Heavy Construction NW'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1042' THEN 'Heavy Construction SW'
      WHEN A.Tasks.WorkOrderTask.Organization.DispatchArea = '1043' THEN 'Heavy Construction SE'
      ELSE A.Tasks.WorkOrderTask.Organization.DispatchArea
    END AS SvC_Cntr,
 
    A.OrderType AS Completed_CSOs,
    A.Tasks.WorkOrderTask.Location.Address.AddressLineCombine AS Address,
    A.Tasks.WorkOrderTask.TaskData.OrderRecord.CompStatus AS CompStatus,
    A.Tasks.WorkOrderTask.Activities.Activity.ActivityData.ElecOrder.TurnDwnCd1 AS TurnDwnCd1,
    A.Tasks.WorkOrderTask.TaskData.OrderRecord.CsrRemarks AS CsrRemarks,
    A.Tasks.WorkOrderTask.TaskTracking.CompletedAt.Value AS TaskCompletedAt,
    A.Tasks.WorkOrderTask.Activities.Activity.ActivityTracking.CompletedByUserId AS CompletedByUserId,
 
    ROW_NUMBER() OVER (
      PARTITION BY A.OrderNumber
      ORDER BY A.OrderUpdateTS DESC
    ) AS rn
 
  FROM \`cnp-datafoundation-prod.EAI_ELEC_OPS.T_ELEC_ORDER_TASKS\` A
 
  WHERE A.OrderUpdateTS >= TIMESTAMP_TRUNC(
          TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 1 DAY),
          DAY
        )
 
    AND A.OrderUpdateTS < TIMESTAMP_TRUNC(
          CURRENT_TIMESTAMP(),
          DAY
        )
 
    AND A.Tasks.WorkOrderTask.eventType = 'Completed'
 
    AND A.Tasks.WorkOrderTask.TaskTracking.CompletedAt.Value IS NOT NULL
 
    AND A.Tasks.WorkOrderTask.TaskData.OrderRecord.CompStatus IN (
      'CMPL',
      'TRDN'
    )
 
    AND A.OrderType IN (
      'RCTOPS',
      'TMDOPS',
      'LOFOPS'
    )
)
 
SELECT
  OrderNumber,
  SvC_Cntr,
  Completed_CSOs,
 
  COUNT(*) OVER (
    PARTITION BY SvC_Cntr, DATE(TaskCompletedAt)
  ) AS Count_of_Daily_CSOs_Per_Serv_Cent,
 
  Address,
  CompStatus,
  TurnDwnCd1,
  CsrRemarks,
  TaskCompletedAt,
  CompletedByUserId
 
FROM base
 
WHERE rn = 1
 
ORDER BY
  TaskCompletedAt,
  OrderNumber
`;
 
  const request = {
    query: query,
    useLegacySql: false,
    maximumBytesBilled: 100000000000
  };

  // Run BigQuery job
  const queryResults = BigQuery.Jobs.query(request, projectId);
  const jobId = queryResults.jobReference.jobId;
 
  // Wait for completion
  let results = BigQuery.Jobs.getQueryResults(projectId, jobId);
 
  while (!results.jobComplete) {
    Utilities.sleep(2000);
    results = BigQuery.Jobs.getQueryResults(projectId, jobId);
  }
 
  // Spreadsheet setup
  const ss = SpreadsheetApp.getActiveSpreadsheet();
 
  let sheet = ss.getSheetByName('Report');
 
  if (!sheet) {
    sheet = ss.insertSheet('Report');
  }
 
  sheet.clearContents();
 
  // Build output array
  const headers = results.schema.fields.map(field => field.name);
 
  const output = [headers];
 
  if (results.rows && results.rows.length > 0) {
 
    results.rows.forEach(row => {
 
      const values = row.f.map(cell => {
        return cell.v !== null ? cell.v : '';
      });
 
      output.push(values);
 
    });
  }
 
  // Write to sheet
  sheet.getRange(
    1,
    1,
    output.length,
    output[0].length
  ).setValues(output);
 
  SpreadsheetApp.flush();
 
  // Date string
  const dateStr = Utilities.formatDate(
    new Date(),
    Session.getScriptTimeZone(),
    'yyyy-MM-dd'
  );
 
  const fileId = ss.getId();
  const token = ScriptApp.getOAuthToken();
 
  // Export URLs
  const xlsxUrl =
    `https://docs.google.com/spreadsheets/d/${fileId}/export?format=xlsx`;
 
  const pdfUrl =
    `https://docs.google.com/spreadsheets/d/${fileId}/export?format=pdf` +
    `&portrait=false` +
    `&fitw=true` +
    `&sheetnames=false` +
    `&printtitle=false` +
    `&pagenumbers=false` +
    `&gridlines=false` +
    `&fzr=false`;
 
  // Export XLSX
  const blobExcel = UrlFetchApp.fetch(xlsxUrl, {
    headers: {
      Authorization: `Bearer ${token}`
    }
  }).getBlob().setName(
    `Daily_CSO_Report_${dateStr}.xlsx`
  );
 
  // Export PDF
  const blobPdf = UrlFetchApp.fetch(pdfUrl, {
    headers: {
      Authorization: `Bearer ${token}`
    }
  }).getBlob().setName(
    `Daily_CSO_Report_${dateStr}.pdf`
  );
 
  // Recipients
  const recipients = [
    'Gregory.Knapp@centerpointenergy.com',
    'Samuel.k.amankwaa@centerpointenergy.com',
    'Binh.Trinh@centerpointenergy.com',
    'Jason.Hughes@centerpointenergy.com',
    'Daryl.Franklin@centerpointenergy.com',
    'Eugene.Guerrero@centerpointenergy.com',
    'keaton.odorisio@centerpointenergy.com',
    'jonquil.dillinger@centerpointenergy.com',
    'andrea.reese@centerpointenergy.com'
  ].join(',');
 
  // Send email
  MailApp.sendEmail({
    to: recipients,
 
    subject: `Daily CSO Report - ${dateStr}`,
 
    body:
      'Good morning.\n\n' +
      'Please find the attached for the completed CSO report. Thank you',
 
    attachments: [
      blobExcel,
      blobPdf
    ]
  });
 
  console.log('✅ Report generated and emailed successfully.');
 
}

