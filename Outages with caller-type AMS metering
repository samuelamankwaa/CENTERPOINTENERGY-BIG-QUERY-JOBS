WITH ranked_events AS (
  SELECT
    ef.EVENTNAME,
    ef.STARTDATETIME,
    ef.RESTOREDDATETIME,
    ef.SERVICECENTER,
    ef.TROUBLE_LVL,
    ss.OUTAGE_CAUSE_CODE,
    cf.CALLERTYPE,
    cf.CALLCODE,
    omsat.action_taken AS ACTION_TAKEN,
    ss.CREW_NOTES AS COMMENTS,     
    ef.DEVICENAME,     
    ef.DURATIONHM,
    ROW_NUMBER() OVER (
      PARTITION BY ef.EVENTNAME 
      ORDER BY ss.ACTION_TAKEN_1 DESC, cf.NO_CALLS DESC
    ) AS row_num
  FROM `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_EVENT_FACT` ef
  LEFT JOIN `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_SERVICE_SUITE` ss ON ef.EVENTNAME = ss.EVENTNAME
  LEFT JOIN `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_CALL_FACT` cf ON cf.EVENTKEY = ef.EVENTKEY
  LEFT JOIN `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_CUSTAFFECTED_INT` ct ON ct.GROUPEVENTKEY = ef.GROUPEVENTKEY 
  LEFT JOIN `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_CUSTSUPPLYLINK_FACT` cl ON cl.CUSTKEY = ct.CUSTKEY
  LEFT JOIN (
    SELECT DISTINCT
      eventname,
      STRING_AGG(action_taken_name, ' , ' ORDER BY eventname) AS action_taken
    FROM `cnp-datafoundation-prod.TECHOPS_FOCALPOINT_VIEWS.V_OMS_ALL_ACTIONS_TAKEN`
    GROUP BY eventname
  ) omsat 
    ON ef.eventname = omsat.eventname 
  WHERE ef.STARTDATETIME BETWEEN "2025-01-01T00:00:00" AND "2025-12-31T23:59:59"
  AND ef.STARTDATETIME NOT BETWEEN "2024-05-16T00:00:00" AND "2024-05-17T23:59:59"
  AND ef.STARTDATETIME NOT BETWEEN "2024-07-08T00:00:00" AND "2024-07-10T23:59:59"
--  AND ef.STARTDATETIME NOT BETWEEN "2025-01-20T00:00:00" AND "2025-01-22T23:59:59"
    AND ef.EXCLUDETROUBLEFLAG = 0
    AND ef.MOMENTARYOUTAGEFLAG = 0
    AND ef.CANCELLEDFLAG = 0
    AND ef.PLANNEDOTGFLAG = 0
    AND ef.NONOUTGCALLFLAG = 0
    AND cf.CALLERTYPE = 'AMS'
    AND ef.ORPHANOUTAGEFLAG = 0
    AND ef.SERVICECENTER NOT IN ('BV', 'EV', 'FB', 'MV', 'RP', 'INDIANA')
)
SELECT * EXCEPT(row_num)
FROM ranked_events
WHERE row_num = 1
ORDER BY STARTDATETIME;

